# ============ 数据库配置 ============
DB_HOST=db                    # Docker 内部服务名（生产）；localhost（本地开发）
DB_PORT=5432
DB_NAME=cooking_plan
DB_USER=cooking_user
DB_PASSWORD=your_database_password_here

# ============ JWT 会话密钥 ============
# 至少 16 字符，推荐用 openssl rand -base64 32 生成
JWT_SECRET=your_jwt_secret_here

# ============ 应用配置 ============
# 本地：http://localhost:3000  生产：https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============ 管理员配置 ============
# npm run seed 时使用，初始化管理员账号
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_strong_password
